# ── DeepSeek V4 接入配置 ──
# 官方文档：https://api-docs.deepseek.com/zh-cn/
# API Key 申请：https://platform.deepseek.com/api_keys
# 留空则自动降级到 mock 模式（不调用任何外部 API）
AI_CORE_LLM_API_KEY=
AI_CORE_LLM_BASE_URL=https://api.deepseek.com
AI_CORE_LLM_MODEL=deepseek-v4-flash

# ── 采样控制（DeepSeek 官方默认值） ──
AI_CORE_LLM_TEMPERATURE=1.0
AI_CORE_LLM_TOP_P=1.0
AI_CORE_LLM_FREQUENCY_PENALTY=0.0
AI_CORE_LLM_PRESENCE_PENALTY=0.0

# ── 输出控制 ──
AI_CORE_LLM_MAX_TOKENS=1024

# ── 思考模式（DeepSeek V4 特色） ──
# 启用后模型会先进行内部推理再输出，token 消耗更高但结果更准确
# 非思考模式（false）响应更快、更省 token，适合简单生成任务
AI_CORE_LLM_THINKING_ENABLED=false
# 推理强度：high（默认）、max（复杂 Agent 场景），仅在 THINKING_ENABLED=true 时生效
AI_CORE_LLM_REASONING_EFFORT=high

# ── JSON 输出模式 ──
# 启用后模型保证输出合法 JSON（需在 prompt 中指示模型生成 JSON）
AI_CORE_LLM_RESPONSE_FORMAT_JSON=true

# ── 请求超时 ──
AI_CORE_LLM_TIMEOUT_SECONDS=60

# ── 行为开关 ──
AI_CORE_ENABLE_LLM=true
AI_CORE_FALLBACK_ON_ERROR=true

# ── 服务配置 ──
AI_CORE_LOG_LEVEL=INFO
