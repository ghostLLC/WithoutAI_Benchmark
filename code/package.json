{
  "name": "without-ai-benchmark",
  "version": "0.1.0",
  "private": true,
  "description": "聚焦「是否应该继续使用 AI」的任务级判断工具",
  "scripts": {
    "dev:web": "pnpm --filter @without-ai/web dev",
    "dev:api": "pnpm --filter @without-ai/api dev",
    "dev:ai": "cd services/ai-core && python -m uvicorn app.main:app --reload --port 8000",
    "build:web": "pnpm --filter @without-ai/web build",
    "build:api": "pnpm --filter @without-ai/api build",
    "build:shared": "pnpm --filter @without-ai/shared build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "test:api": "pnpm --filter @without-ai/api test",
    "test:ai": "cd services/ai-core && python -m pytest tests/ -v",
    "test": "pnpm run test:api && pnpm run test:ai"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  }
}
